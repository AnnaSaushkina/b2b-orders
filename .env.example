# Скопируй в .env и при необходимости поправь значения.
# .env в git не попадает (см. .gitignore), .env.example — попадает.
# Docker Compose автоматически подхватывает .env из корня для подстановки ${...}.

# --- PostgreSQL ---
POSTGRES_USER=marven
POSTGRES_PASSWORD=marven
POSTGRES_DB=marven

# --- Подключения приложения ---
# Для локальной разработки (API на хосте, инфра в docker-compose.yml):
DATABASE_URL=postgresql://marven:marven@localhost:5432/marven?schema=public
REDIS_URL=redis://localhost:6379

# Порт API
PORT=4000
